local mobileFlyGui = Instance.new("ScreenGui")
mobileFlyGui.Name = randName1
mobileFlyGui.ResetOnSpawn = false
mobileFlyGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local mobileFrame = Instance.new("Frame")
