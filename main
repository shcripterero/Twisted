mobileFrame.Position = UDim2.new(1, -150, 0.5, -70)
mobileFrame.BackgroundTransparency = 1
mobileFrame.Visible = false
mobileFrame.Parent = mobileFlyGui

local function makeButton(text, pos, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 30)
    btn.Position = pos
    btn.BackgroundColor3 = color or Color3.fromRGB(30,30,35)
    btn.BackgroundTransparency = 0.3
    btn.Text = text
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    Instance.new("UICorner", btn)
    btn.Parent = mobileFrame
    return btn
end

local forwardBtn = makeButton("ūüöÄ FORWARD", UDim2.new(0,0,0,0), Color3.fromRGB(0,150,150))
local upBtn = makeButton("‚Ė≤ UP", UDim2.new(0,0,0,35))
local downBtn = makeButton("‚Ėľ DOWN", UDim2.new(0,0,0,70))
local exitBtn = makeButton("EXIT CAR", UDim2.new(0,0,0,105), Color3.fromRGB(150,0,0))

forwardBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        TouchFlyForward = true
    end
end)
forwardBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        TouchFlyForward = false
    end
end)
upBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        TouchFlyUp = true
    end
end)
upBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        TouchFlyUp = false
    end
end)
downBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        TouchFlyDown = true
    end
end)
downBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        TouchFlyDown = false
    end
end)
exitBtn.MouseButton1Click:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid.Sit = false
        LocalPlayer.Character.Humanoid.Jump = true
    end
end)

