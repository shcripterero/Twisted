-- Wait for character
while not LocalPlayer.Character do task.wait() end
local Camera = workspace.CurrentCamera or workspace:WaitForChild("Camera")

--==================================================================================================
--                                      ANTI-DETECTION LAYERS
--==================================================================================================
-- Randomise variable names each run to avoid static patterns.
local function randomString(len)
    local chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    local out = ""
    for _ = 1, len do
        out = out .. chars:sub(math.random(1, #chars), math.random(1, #chars))
    end
    return out
end

-- Randomise names for GUI elements and physics objects (prevent pattern scanning)
local randName1 = randomString(12)
local randName2 = randomString(12)
local randName3 = randomString(12)
local randName4 = randomString(12)
local randName5 = randomString(12)

-- Use pcall to suppress errors (anti‚ÄĎdetection)
local function safe(fn, ...)
    local ok, res = pcall(fn, ...)
    if not ok then return nil end
    return res
end

-- Randomised delays for loops to avoid timing patterns
local function randDelay(min, max)
    return min + math.random() * (max - min)
end

