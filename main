-- Variables
local CarFlySpeed = 150
local CarGroundSpeed = 120
local TouchFlyForward = false
local TouchFlyUp = false
local TouchFlyDown = false
local _OriginalLighting = {}
local _FpsBoostConnection = nil
local myCar = nil
local flyRoot = nil

--==================================================================================================
--                                    KEY SYSTEM BYPASS
--==================================================================================================
-- Destroy the key GUI immediately and block it from reappearing
local function BypassKey()
    -- Find and destroy any key GUI
    local keyGui = LocalPlayer.PlayerGui:FindFirstChild("KeyGui")
    if keyGui then keyGui:Destroy() end

    -- Watch for newly added key GUI and destroy it
    local conn = LocalPlayer.PlayerGui.ChildAdded:Connect(function(child)
        if child.Name:lower():match("key") then
            child:Destroy()
        end
    end)

    -- Try to find the remote event used for key verification and override it
    local keyRemote = nil
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("RemoteEvent") and v.Name:lower():match("key") then
            keyRemote = v
            break
        end
    end
    if keyRemote then
        local oldFire = keyRemote.FireServer
        keyRemote.FireServer = function(self, ...)
            local args = {...}
            if args[1] and tostring(args[1]):match("key") then
                return true
            end
            return oldFire(self, ...)
        end
    end

    -- Additionally, override any global key validation function (if exists)
    if getgenv and getgenv().isKeyValid then
        getgenv().isKeyValid = true
    end
    if getgenv and getgenv().checkKey then
        getgenv().checkKey = function() return true end
    end

    return conn
end

-- Run key bypass
local keyWatcher = BypassKey()

--==================================================================================================
--                                    SMOOTH TELEPORT
--==================================================================================================
local function smoothTeleport(hrp, targetPos, steps)
    steps = steps or 8
    task.spawn(function()
        local startPos = hrp.CFrame.Position
        for i = 1, steps do
            task.wait(0.05)
            if hrp and hrp.Parent then
                local alpha = i / steps
                hrp.CFrame = CFrame.new(startPos:Lerp(targetPos, alpha))
            end
        end
    end)
end

