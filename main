-- Tab: LOCAL
local LocalTab = Window:CreateTab("Local", nil)
LocalTab:CreateSection("Lighting")
LocalTab:CreateToggle({ Name = "Fullbright", CurrentValue = false, Callback = function(v) Flags.Fullbright = v end })
