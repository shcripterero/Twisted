-- Tab: CAR
local CarTab = Window:CreateTab("Car", nil)
CarTab:CreateSection("Car Flight")
CarTab:CreateToggle({ Name = "Car Fly (W = forward, Space = up, C = down, touch buttons appear)", CurrentValue = false, Callback = function(v) Flags.CarFly = v end })
CarTab:CreateSlider({ Name = "Car Fly Speed", Min = 50, Max = 300, Default = 150, CurrentValue = 150, Callback = function(v) CarFlySpeed = v end })
CarTab:CreateSection("Car Speed Boost")
CarTab:CreateToggle({ Name = "Car Speed Boost (drive fast on ground)", CurrentValue = false, Callback = function(v) Flags.CarSpeedBoost = v end })
CarTab:CreateSlider({ Name = "Ground Speed", Min = 50, Max = 250, Default = 120, CurrentValue = 120, Callback = function(v) CarGroundSpeed = v end })
CarTab:CreateSection("Tornado Protection")
CarTab:CreateToggle({ Name = "Vehicle Tornado Protection", CurrentValue = false, Callback = function(v) Flags.VehicleWindProtect = v end })
CarTab:CreateSection("Other")
CarTab:CreateToggle({ Name = "My Car ESP", CurrentValue = false, Callback = function(v) Flags.MyCarEsp = v end })
CarTab:CreateButton({ Name = "Teleport To Car", Callback = function()
    if myCar and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        smoothTeleport(LocalPlayer.Character.HumanoidRootPart, myCar.Position, 24)
    end
end })

